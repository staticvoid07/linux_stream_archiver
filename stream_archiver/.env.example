# ============================================
# Twitch Configuration
# ============================================
TWITCH_CHANNELS=channelname1,channelname2
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ============================================
# Recording Settings
# ============================================
DOWNLOAD_FOLDER=/var/lib/stream-archiver/downloads
CHECK_INTERVAL=60
STREAM_QUALITY=best

# Per-channel overrides (replace CHANNELNAME with the actual channel name in caps)
# CHANNEL_CHANNELNAME1_QUALITY=720p
# CHANNEL_CHANNELNAME1_PLAYLIST=PLxxxxxxxxx
# CHANNEL_CHANNELNAME1_INTERVAL=30

# ============================================
# YouTube Upload Settings
# ============================================
YOUTUBE_CLIENT_SECRETS=/opt/stream-archiver/client_secrets.json
YOUTUBE_TOKEN_FILE=/var/lib/stream-archiver/youtube_token.pickle
YOUTUBE_CATEGORY=20
YOUTUBE_PRIVACY=unlisted
# Optional: add all uploads to a default playlist
YOUTUBE_PLAYLIST_ID=

# ============================================
# File Paths & Logging
# ============================================
UPLOAD_HISTORY_FILE=/var/lib/stream-archiver/upload_history.json
STATUS_FILE=/var/lib/stream-archiver/status.json
LOG_FILE=/var/log/stream-archiver/archiver.log
# Set to false to log only to stdout (journald captures stdout automatically)
LOG_TO_FILE=true

# ============================================
# HTTP Status Server
# ============================================
STATUS_SERVER_ENABLED=true
# Bind to 127.0.0.1 for local-only access; use 0.0.0.0 to expose on LAN
STATUS_SERVER_HOST=127.0.0.1
STATUS_SERVER_PORT=8080

# ============================================
# Webhook Notifications
# ============================================
# Supported types: discord, slack, generic
WEBHOOK_URL=
WEBHOOK_TYPE=discord

# Control which events send a webhook (true/false)
NOTIFY_STREAM_ONLINE=true
NOTIFY_RECORDING_START=true
NOTIFY_RECORDING_END=false
NOTIFY_UPLOAD_START=false
NOTIFY_UPLOAD_END=true
NOTIFY_UPLOAD_FAIL=true
NOTIFY_ERROR=true
